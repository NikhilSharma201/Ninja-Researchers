# Ninja-Researchers Environment Configuration
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control (keep .env.example in git instead)

# ============================================================================
# LLM PROVIDER CONFIGURATIONS
# ============================================================================

# Groq API (Recommended - Free, Fast, No Credit Card)
# Get API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API (Premium option)
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4  # or gpt-3.5-turbo

# Anthropic API (Optional)
# Get API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================================
# ACADEMIC API CONFIGURATIONS
# ============================================================================

# Semantic Scholar API
# Sign up at: https://www.semanticscholar.org/tools/api
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key

# arXiv API (Usually no key needed, but optional for higher limits)
ARXIV_API_KEY=optional_if_needed

# PubMed API (Usually no key needed)
PUBMED_API_KEY=optional_if_needed

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Primary vector database type
# Options: chromadb, faiss, weaviate, pinecone
VECTOR_DB_TYPE=chromadb

# Database storage path
DB_PATH=./data/chroma_db/

# ChromaDB specific settings
CHROMA_COLLECTION_NAME=papers
CHROMA_PERSISTENCE_DIR=./data/chroma_db/

# FAISS specific settings
FAISS_INDEX_PATH=./data/faiss_index/
FAISS_USE_GPU=false  # Set to true if you have CUDA

# ============================================================================
# EMBEDDING CONFIGURATION
# ============================================================================

# Embedding model provider
# Options: sentence-transformers, openai, cohere
EMBEDDING_PROVIDER=sentence-transformers

# Sentence Transformers model
# Default: all-MiniLM-L6-v2 (Fast, lightweight)
# Large option: all-mpnet-base-v2 (Better quality, slower)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Embedding generation batch size
EMBEDDING_BATCH_SIZE=32

# ============================================================================
# RETRIEVAL CONFIGURATION
# ============================================================================

# Maximum number of papers to retrieve per query
MAX_PAPERS=50

# Relevance score threshold (0.0 - 1.0)
SCORE_THRESHOLD=0.3

# Paper sources to search
# Comma-separated: arxiv, pubmed, semantic_scholar
PAPER_SOURCES=arxiv,pubmed,semantic_scholar

# Search timeout (seconds)
SEARCH_TIMEOUT=30

# ============================================================================
# REPORT GENERATION
# ============================================================================

# Report format preference
# Options: markdown, pdf, json, html, latex
DEFAULT_REPORT_FORMAT=markdown

# Report export directory
REPORT_EXPORT_DIR=./data/reports/

# PDF output settings
PDF_PAGE_SIZE=A4
PDF_FONT_SIZE=11
PDF_INCLUDE_TOC=true

# ============================================================================
# CACHING CONFIGURATION
# ============================================================================

# Enable/disable caching
ENABLE_CACHING=true

# Cache time-to-live (TTL) in seconds
# 86400 = 24 hours, 604800 = 7 days
CACHE_TTL=604800

# Maximum cache size (in GB)
MAX_CACHE_SIZE=10

# Cache cleanup interval (seconds)
CACHE_CLEANUP_INTERVAL=3600

# ============================================================================
# LOGGING & DEBUG
# ============================================================================

# Logging level
# Options: CRITICAL, ERROR, WARNING, INFO, DEBUG
LOG_LEVEL=INFO

# Enable debug mode (more verbose logging)
DEBUG_MODE=false

# Enable request/response tracing
TRACE_REQUESTS=false

# Log file path
LOG_FILE_PATH=./logs/ninja-researchers.log

# ============================================================================
# RATE LIMITING
# ============================================================================

# Rate limiting for APIs
ENABLE_RATE_LIMITING=true

# Requests per minute
REQUESTS_PER_MINUTE=60

# Concurrent requests
MAX_CONCURRENT_REQUESTS=5

# ============================================================================
# STREAMLIT CONFIGURATION
# ============================================================================

# Streamlit server port
STREAMLIT_PORT=8501

# Streamlit server address
STREAMLIT_ADDRESS=localhost

# Enable Streamlit logger
STREAMLIT_LOGGER_ENABLED=true

# ============================================================================
# PROXY & NETWORK
# ============================================================================

# HTTP Proxy (if needed)
HTTP_PROXY=

# HTTPS Proxy (if needed)
HTTPS_PROXY=

# No proxy domains
NO_PROXY=localhost,127.0.0.1

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable devil's advocate agent
ENABLE_DEVILS_ADVOCATE=true

# Enable contradiction detection
ENABLE_CONTRADICTION_DETECTION=true

# Enable gap analysis
ENABLE_GAP_ANALYSIS=true

# Enable claim confidence scoring
ENABLE_CONFIDENCE_SCORING=true

# ============================================================================
# OPTIONAL: EXTERNAL INTEGRATIONS
# ============================================================================

# Slack Integration
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# Email Integration
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# MongoDB Integration (for storing reports)
MONGODB_URI=

# Redis Integration (for caching)
REDIS_URL=

# ============================================================================
# SECURITY
# ============================================================================

# API rate limit bypass (use with caution)
RATE_LIMIT_BYPASS_KEY=

# Enable CORS for API endpoints
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# Session timeout (minutes)
SESSION_TIMEOUT=60

; End of configuration file
